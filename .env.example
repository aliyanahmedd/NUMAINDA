# Rename this file to .env and fill in your API keys
# Never commit .env to git

HUNTER_API_KEY=your_hunter_io_key_here
VIRUSTOTAL_API_KEY=your_virustotal_key_here
GITHUB_TOKEN=your_github_token_here
BREACHDIRECTORY_API_KEY=your_rapidapi_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional - improves results if provided
SHODAN_API_KEY=your_shodan_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here    # free at abuseipdb.com
